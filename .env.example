# ---- Server ----
PORT=4317
DB_PATH=hoopedorc.db
# Loopback by default. Set to 0.0.0.0 (or a tailnet IP) only for remote access
# (e.g. over Tailscale) — and set API_TOKEN below when you do.
HOST=127.0.0.1
# Extra allowed browser origins for CORS, comma-separated. The dev web app's
# own origins (localhost/127.0.0.1:5173) are always allowed; you shouldn't
# need this unless you're serving the web app from somewhere else.
# CORS_ORIGINS=
# Off by default (frictionless solo localhost use). Set this to require
# `Authorization: Bearer <token>` on every API request — required if HOST is
# not loopback, unless ALLOW_UNAUTHENTICATED=1.
# API_TOKEN=
# Explicit opt-in to run with HOST set beyond loopback and no API_TOKEN.
# Not recommended — anything that can reach the host gets full control.
# ALLOW_UNAUTHENTICATED=0
# How long agent output logs are kept before being pruned (runs on boot and
# daily). Each task is also capped at its newest ~2000 rows regardless of age.
LOG_RETENTION_DAYS=14
# How long notifications are kept before being pruned (runs on boot and
# daily). A pending approval (no response yet) is never pruned regardless
# of age, no matter how old.
NOTIFICATION_RETENTION_DAYS=30
# Where periodic DB backups go (runs on boot and daily) and how many to keep.
# Defaults to a "backups" dir next to DB_PATH. No-op for MOCK=1 (in-memory).
# DB_BACKUP_DIR=
DB_BACKUP_KEEP=7

# ---- OpenCode ----
# Non-Claude models run via the `opencode run` CLI. By default each run is
# standalone (no server needed). Optionally centralize sessions on one server:
#   opencode serve --port 4096   (then set the URL below to attach runs to it)
# OPENCODE_BASE_URL=http://localhost:4096

# ---- Model authentication ----
# Hoopedorc does not accept or forward provider API keys. Authenticate each CLI
# under the same OS user that runs Hoopedorc (`claude auth status`, `codex login
# status`, `opencode auth list`). OpenCode keeps any provider keys/OAuth grants
# in its own credential store; Claude and Codex use their own login state. For a
# Z.AI Coding Plan subscription, configure a distinct `zai-coding-plan` OpenCode
# provider with base URL `https://api.z.ai/api/coding/paas/v4`; the general Z.AI
# endpoint is billed separately from the Coding Plan.

# ---- Telegram (v1.1, bidirectional control) ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- GitHub ----
# Uses the `gh` CLI auth already on this machine (run `gh auth status` to verify).
