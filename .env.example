# ---- Server ----
PORT=4317
DB_PATH=hoopedorc.db

# ---- OpenCode ----
# Non-Claude models run via the `opencode run` CLI. By default each run is
# standalone (no server needed). Optionally centralize sessions on one server:
#   opencode serve --port 4096   (then set the URL below to attach runs to it)
# OPENCODE_BASE_URL=http://localhost:4096

# ---- Provider keys (names only here; put real values in .env, never commit) ----
DEEPSEEK_API_KEY=
GLM_API_KEY=
OPENROUTER_API_KEY=
# Grok is OAuth *inside* OpenCode — no key needed here.
# Claude runs via Claude Code using your logged-in Pro subscription — no key here.

# ---- Telegram (v1.1, bidirectional control) ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- GitHub ----
# Uses the `gh` CLI auth already on this machine (run `gh auth status` to verify).
